# Neon Postgres (same as frontend)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Vercel Blob (for uploading generated images)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Seedream 4.5 API (Volcengine)
SEEDREAM_API_KEY=your_seedream_api_key
SEEDREAM_API_ENDPOINT=https://operator.las.cn-beijing.volces.com/api/v1

# Microsoft Teams Webhook
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# App URL (for links in notifications)
APP_URL=https://your-app.vercel.app

# Polling interval (seconds)
POLL_INTERVAL_SECONDS=30
