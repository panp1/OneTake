  "generation_pipeline": {
    "entrypoint": "compute_jobs claim",
    "terminal_state": "review",
    "stages": [
      {
        "stage_number": 1,
        "name": "Strategic Intelligence",
        "inputs": [
          "intake request",
          "target regions",
          "target languages",
          "form_data"
        ],
        "outputs": [
          "cultural research",
          "personas",
          "campaign strategies",
          "brief_data",
          "design_direction",
          "derived_requirements"
        ],
        "feeds_next_stage": [
          "personas",
          "design_direction",
          "derived_requirements",
          "brief_data",
          "campaign_strategies"
        ]
      },
      {
        "stage_number": 2,
        "name": "Character-Driven Image Generation",
        "inputs": [
          "personas",
          "design_direction",
          "regions",
          "languages"
        ],
        "outputs": [
          "actor profiles",
          "validated seed image per actor",
          "image variations",
          "base_image assets"
        ],
        "feeds_next_stage": [
          "actor profiles",
          "base_image assets",
          "validated visual identity"
        ]
      },
      {
        "stage_number": 3,
        "name": "Copy Generation",
        "inputs": [
          "brief",
          "personas",
          "design_direction",
          "regions",
          "languages",
          "channel strategy"
        ],
        "outputs": [
          "persona x channel x language copy variants",
          "copy assets"
        ],
        "feeds_next_stage": [
          "approved copy variants by persona/platform/language"
        ]
      },
      {
        "stage_number": 4,
        "name": "Layout Composition",
        "inputs": [
          "actors",
          "base images",
          "copy assets",
          "brief",
          "design direction",
          "platform specs"
        ],
        "outputs": [
          "composed_creative assets",
          "carousel assets",
          "overlay renders",
          "final renders"
        ],
        "feeds_next_stage": [
          "final creative direction",
          "rendered creative assets",
          "messaging context for video"
        ]
      },
      {
        "stage_number": 5,
        "name": "Video Generation",
        "optional": true,
        "inputs": [
          "personas",
          "actors",
          "brief",
          "stage 2 images",
          "stage 3/4 messaging context"
        ],
        "outputs": [
          "short UGC-style video assets"
        ],
        "feeds_next_stage": [
          "none"
        ]
      }
    ]
  }
}
