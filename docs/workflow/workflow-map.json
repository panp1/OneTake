{
  "version": "2026-04-09",
  "repository": "centric-intake",
  "artifacts": [
    {
      "name": "end_to_end_workflow",
      "type": "mermaid",
      "path": "docs/workflow/end-to-end-workflow.mmd"
    },
    {
      "name": "generation_pipeline",
      "type": "mermaid",
      "path": "docs/workflow/generation-pipeline.mmd"
