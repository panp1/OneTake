  ],
  "roles": [
    "recruiter",
    "admin",
    "marketing_manager",
    "designer",
    "agency",
    "worker",
    "database"
  ],
  "status_flow": [
    {
      "status": "draft",
      "meaning": "initial or returned-for-changes state"
    },
    {
      "status": "generating",
      "meaning": "compute job queued or in progress"
    },
    {
      "status": "review",
      "meaning": "generation complete, awaiting marketing approval"
    },
    {
      "status": "approved",
      "meaning": "package approved and ready for designer/recruiter/agency handoff"
    },
    {
      "status": "sent",
      "meaning": "final package delivered downstream"
    },
    {
      "status": "rejected",
      "meaning": "request rejected"
    },
    {
      "status": "split",
      "meaning": "parent campaign split into child campaigns by worker"
    }
  ],
